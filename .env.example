# =============================================
# Linear Pipeline 환경변수
# 이 파일을 .env 로 복사한 뒤 값을 채워주세요
# cp .env.example .env
# =============================================

# ─── Linear ───────────────────────────────────
LINEAR_API_KEY=lin_api_xxxxxxxxxxxxxxxxxxxx

# Linear Webhook 서명 검증용 (Linear Webhook 설정에서 확인)
LINEAR_WEBHOOK_SECRET=lin_wh_xxxxxxxxxxxxxxxxxxxx

# Linear 각 상태(State)의 ID
# 조회 방법:
#   curl -s -X POST https://api.linear.app/graphql \
#     -H "Authorization: lin_api_xxx" \
#     -H "Content-Type: application/json" \
#     -d '{"query":"{ workflowStates { nodes { id name } } }"}' \
#     | python3 -m json.tool
LINEAR_TODO_STATE_ID=
LINEAR_PLAN_REVIEW_STATE_ID=
LINEAR_DEVELOP_STATE_ID=
LINEAR_REVIEW_STATE_ID=
LINEAR_REVIEWED_STATE_ID=
LINEAR_DONE_STATE_ID=

# ─── GitHub ───────────────────────────────────
# PAT 권한: repo, pull_requests, workflow
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxx
GITHUB_REPO=your-username/your-repo

# ─── 개발 서버 ────────────────────────────────
DEV_SERVER_URL=https://test.your-domain.com

# ─── 프로젝트 경로 ────────────────────────────
# 개발 서버와 공유되는 /workspace 안의 실제 프로젝트 폴더
PROJECT_ROOT=/workspace/claude_dev

# ─── Slack ────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# ─── Webhook 서버 ─────────────────────────────
WEBHOOK_PORT=3001
